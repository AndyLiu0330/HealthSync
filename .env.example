# Copy this file to `.env` for local development.
# Create these values in your own Google Cloud project:
# https://console.cloud.google.com/apis/credentials
#
# Do not commit `.env`, OAuth client secrets, downloaded credential JSON files,
# or local OAuth token files.

HEALTHSYNC_CLIENT_ID=your-client-id.apps.googleusercontent.com
HEALTHSYNC_CLIENT_SECRET=your-client-secret
